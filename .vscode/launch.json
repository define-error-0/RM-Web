{
    // 使用 ${workspaceFolder} 指向当前工作区，避免项目移动后路径失效
    // type 为 chrome 时会用 Chrome 打开；若要用 Edge，改为 "type": "msedge"
    "version": "0.2.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "launch",
            "name": "Open Connection.html",
            "file": "${workspaceFolder}/Connection.html"
        }
    ]
}
